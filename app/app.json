{
  "expo": {
    "name": "Palm",
    "slug": "palm-app",
    "scheme": "palm",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F8F6",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "android"
    ],
    "android": {
      "package": "io.usepalm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D3B2E"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#F6F8F6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c7c03273-1a5c-45d0-8a86-b71bb646cd6c"
      }
    }
  }
}
