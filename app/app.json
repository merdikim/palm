{
  "expo": {
    "name": "Palm",
    "slug": "palm-app",
    "scheme": "palm",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0d12",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b0d12",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.usepalm.app"
    },
    "android": {
      "package": "io.usepalm.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "c7c03273-1a5c-45d0-8a86-b71bb646cd6c"
      }
    }
  }
}
